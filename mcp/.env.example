# OpenAI — used for RAG embeddings
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Pinecone — RAG vector store
PINECONE_API_KEY=
PINECONE_INDEX_NAME=trading-bot
RAG_TOP_K=5

# PostgreSQL (asyncpg format) — portfolio/alerts
DATABASE_URL=

# Bind address. Defaults are deploy-friendly (0.0.0.0, and $PORT when the platform
# provides it), so you usually don't need to set these at all.
# Local dev binds 0.0.0.0:8001 (reachable at http://localhost:8001/mcp).
# On Render/Railway/Fly: leave both UNSET — $PORT is used automatically.
# MCP_SERVER_HOST=0.0.0.0
# MCP_SERVER_PORT=8001
